<idea-plugin>
    <dependencies>
        <module name="intellij.platform.frontend"/>
        <module name="accurecode.jetbrains.shared"/>
    </dependencies>

    <resource-bundle>messages.AccureBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="ai.accurecode.client.migration.AccureMigrationService"/>
        <applicationService serviceImplementation="ai.accurecode.client.autocomplete.AccureAutocompleteSettingsService"/>
        <customPasteProvider implementation="ai.accurecode.client.session.ui.prompt.PromptAttachmentPasteProvider"/>

        <notificationGroup id="Accure Code"
                           displayType="BALLOON"
                           bundle="messages.AccureBundle"
                           key="notification.group.accurecode"/>

        <toolWindow id="Accure Code"
                    anchor="left"
                    icon="/icons/accure.svg"
                    factoryClass="ai.accurecode.client.AccureToolWindowFactory"/>

        <fileEditorProvider id="AccureVfsEditor" implementation="ai.accurecode.client.vfs.AccureFileEditorProvider"/>

        <applicationConfigurable
                parentId="tools"
                id="ai.accurecode.jetbrains.settings"
                instance="ai.accurecode.client.settings.AccureSettingsConfigurable"
                bundle="messages.AccureBundle"
                key="settings.accurecode.displayName"/>

        <applicationConfigurable
                parentId="ai.accurecode.jetbrains.settings"
                id="ai.accurecode.jetbrains.settings.profile"
                groupWeight="2"
                instance="ai.accurecode.client.settings.profile.UserProfileConfigurable"
                bundle="messages.AccureBundle"
                key="settings.profile.displayName"/>

        <applicationConfigurable
                parentId="ai.accurecode.jetbrains.settings"
                id="ai.accurecode.jetbrains.settings.models"
                groupWeight="1"
                instance="ai.accurecode.client.settings.models.ModelsConfigurable"
                bundle="messages.AccureBundle"
                key="settings.models.displayName"/>

        <applicationConfigurable
                parentId="ai.accurecode.jetbrains.settings"
                id="ai.accurecode.jetbrains.settings.providers"
                groupWeight="1"
                instance="ai.accurecode.client.settings.providers.ProvidersConfigurable"
                bundle="messages.AccureBundle"
                key="settings.providers.displayName"/>

        <registryKey key="accure.session.condense"
                     description="Enable event condensing in the session update queue (merges redundant snapshots before model delivery)."
                     defaultValue="true"
                     restartRequired="false"
                     overrides="false"/>
        <registryKey key="accure.session.flushMs"
                     description="Session update queue flush cadence in milliseconds."
                     defaultValue="150"
                     restartRequired="false"
                     overrides="false"/>
        <registryKey key="accure.session.inactive.disposeTimeoutMs"
                     description="Milliseconds before hidden session UI is disposed after switching away."
                     defaultValue="180000"
                     restartRequired="false"
                     overrides="false"/>
    </extensions>

    <applicationListeners>
        <listener class="ai.accurecode.client.plugin.AccureFrontendDynamicPluginListener"
                  topic="com.intellij.ide.plugins.DynamicPluginListener"/>
    </applicationListeners>

    <actions>
        <action id="Accure.Restart"
                class="ai.accurecode.client.actions.RestartAccureAction"/>

        <action id="Accure.Reinstall"
                class="ai.accurecode.client.actions.ReinstallAccureAction"/>

        <action id="Accure.OpenSettings"
                class="ai.accurecode.client.actions.OpenSettingsAction"/>

        <action id="Accure.OpenLocalConfig"
                class="ai.accurecode.client.actions.OpenLocalConfigAction"/>

        <action id="Accure.OpenGlobalConfig"
                class="ai.accurecode.client.actions.OpenGlobalConfigAction"/>

        <group id="Accure.CliGroup" text="CLI" popup="true">
            <reference ref="Accure.Restart"/>
            <reference ref="Accure.Reinstall"/>
        </group>

        <group id="Accure.OpenConfigGroup" text="Config Files" popup="true">
            <reference ref="Accure.OpenLocalConfig"/>
            <reference ref="Accure.OpenGlobalConfig"/>
        </group>

        <group id="Accure.SettingsGroup">
            <reference ref="Accure.OpenSettings"/>
            <separator/>
            <reference ref="Accure.OpenConfigGroup"/>
            <separator/>
            <reference ref="Accure.CliGroup"/>
        </group>

        <action id="Accure.Settings"
                class="ai.accurecode.client.actions.AccureSettingsAction"
                icon="AllIcons.General.GearPlain"/>

        <action id="Accure.NewSession"
                class="ai.accurecode.client.actions.NewSessionAction"/>

        <action id="Accure.History"
                class="ai.accurecode.client.actions.HistoryAction"/>

        <!-- Declarative toolbar group for the Accure tool window title bar -->
        <group id="Accure.ToolWindowToolbar">
            <reference ref="Accure.NewSession"/>
            <reference ref="Accure.History"/>
            <reference ref="Accure.Settings"/>
        </group>

        <action id="Accure.SendPrompt"
                class="ai.accurecode.client.actions.SendPromptAction"
                text="Send Prompt"
                description="Send the current Accure prompt">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="ENTER"/>
            <keyboard-shortcut keymap="Mac OS X 10.5+"
                               first-keystroke="meta ENTER"/>
            <keyboard-shortcut keymap="$default"
                               first-keystroke="control ENTER"/>
        </action>

        <action id="Accure.StopSession"
                class="ai.accurecode.client.actions.StopSessionAction"
                text="Stop Session"
                description="Stop the current Accure session">
            <keyboard-shortcut keymap="$default"
                               first-keystroke="alt S"/>
        </action>

        <action id="Accure.Session.Open"
                class="ai.accurecode.client.actions.OpenSessionAction">
            <keyboard-shortcut keymap="$default" first-keystroke="ENTER"/>
        </action>

        <action id="Accure.Session.Rename"
                class="ai.accurecode.client.actions.RenameSessionAction"
                use-shortcut-of="RenameElement"/>

        <action id="Accure.Session.Delete"
                class="ai.accurecode.client.actions.DeleteSessionAction"
                use-shortcut-of="$Delete"/>

        <group id="Accure.History.ContextMenu">
            <reference ref="Accure.Session.Open"/>
            <separator/>
            <reference ref="Accure.Session.Rename"/>
            <reference ref="Accure.Session.Delete"/>
        </group>

        <group id="Accure.Session.ContextMenu">
            <reference ref="$Copy"/>
        </group>
    </actions>
</idea-plugin>
