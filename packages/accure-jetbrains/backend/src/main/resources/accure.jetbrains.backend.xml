<idea-plugin>
    <dependencies>
        <module name="intellij.platform.backend"/>
        <module name="intellij.platform.kernel.backend"/>
        <module name="accurecode.jetbrains.shared"/>
    </dependencies>

    <extensions defaultExtensionNs="com.intellij">
        <platform.rpc.backend.remoteApiProvider implementation="ai.accurecode.backend.rpc.AccureAppRpcApiProvider"/>
        <platform.rpc.backend.remoteApiProvider implementation="ai.accurecode.backend.rpc.AccureProviderRpcApiProvider"/>
        <platform.rpc.backend.remoteApiProvider implementation="ai.accurecode.backend.rpc.AccureProjectRpcApiProvider"/>
        <platform.rpc.backend.remoteApiProvider implementation="ai.accurecode.backend.rpc.AccureSessionRpcApiProvider"/>
        <platform.rpc.backend.remoteApiProvider implementation="ai.accurecode.backend.rpc.AccureMigrationRpcApiProvider"/>
        <applicationService serviceImplementation="ai.accurecode.backend.migration.AccureBackendLegacyMigrationStoreService"/>
    </extensions>

    <applicationListeners>
        <listener class="ai.accurecode.backend.plugin.AccureBackendDynamicPluginListener"
                  topic="com.intellij.ide.plugins.DynamicPluginListener"/>
    </applicationListeners>
</idea-plugin>
