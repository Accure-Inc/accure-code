    "submenus": [
      {
        "id": "accure-code.editorContextMenu",
        "label": "Accure Code"
      },
      {
        "id": "accure-code.terminalContextMenu",
        "label": "Accure Code"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "accure-code.sidebarTitle.plusButtonClicked",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.historyButtonClicked",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.agentManagerOpen",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.kiloClawOpen",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.marketplaceButtonClicked",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.profileButtonClicked",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.settingsButtonClicked",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "accure-code.sidebarTitle.plusButtonClicked",
          "group": "navigation@0",
          "when": "view == accure-code.SidebarProvider"
        },
        {
          "command": "accure-code.sidebarTitle.historyButtonClicked",
          "group": "navigation@1",
          "when": "view == accure-code.SidebarProvider"
        },
        {
          "command": "accure-code.sidebarTitle.agentManagerOpen",
          "group": "navigation@2",
          "when": "view == accure-code.SidebarProvider"
        },
        {
          "command": "accure-code.sidebarTitle.kiloClawOpen",
          "group": "navigation@3",
          "when": "false"
        },
        {
          "command": "accure-code.sidebarTitle.marketplaceButtonClicked",
          "group": "navigation@4",
          "when": "view == accure-code.SidebarProvider"
        },
        {
          "command": "accure-code.sidebarTitle.profileButtonClicked",
          "group": "navigation@5",
          "when": "view == accure-code.SidebarProvider"
        },
        {
          "command": "accure-code.sidebarTitle.settingsButtonClicked",
          "group": "navigation@6",
          "when": "view == accure-code.SidebarProvider"
        }
      ],
      "scm/title": [
        {
          "command": "accure-code.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "scm/input": [
        {
          "command": "accure-code.generateCommitMessage",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ],
      "editor/title": [
        {
          "command": "accure-code.openInTab",
          "group": "navigation",
          "when": "true"
        },
        {
          "command": "accure-code.plusButtonClicked",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == accure-code.TabPanel"
        },
        {
          "command": "accure-code.historyButtonClicked",
          "group": "navigation@1",
          "when": "activeWebviewPanelId == accure-code.TabPanel"
        },
        {
          "command": "accure-code.profileButtonClicked",
          "group": "navigation@2",
          "when": "activeWebviewPanelId == accure-code.TabPanel"
        },
        {
          "command": "accure-code.settingsButtonClicked",
          "group": "navigation@3",
          "when": "activeWebviewPanelId == accure-code.TabPanel"
        }
      ],
      "editor/context": [
        {
          "submenu": "accure-code.editorContextMenu",
          "group": "1_kilocode"
        }
      ],
      "accure-code.editorContextMenu": [
        {
          "command": "accure-code.explainCode",
          "group": "1_actions@1"
        },
        {
          "command": "accure-code.fixCode",
          "group": "1_actions@2"
        },
        {
          "command": "accure-code.improveCode",
          "group": "1_actions@3"
        },
        {
          "command": "accure-code.addToContext",
          "group": "1_actions@4"
        }
      ],
      "terminal/context": [
        {
          "submenu": "accure-code.terminalContextMenu",
          "group": "2_kilocode"
        }
      ],
      "accure-code.terminalContextMenu": [
        {
          "command": "accure-code.terminalAddToContext",
          "group": "1_actions@1"
        },
        {
          "command": "accure-code.terminalFixCommand",
          "group": "1_actions@2"
        },
        {
          "command": "accure-code.terminalExplainCommand",
          "group": "1_actions@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "accure-code.focusChatInput",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "accure-code.toggleAutoApprove",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      },
      {
        "command": "accure-code.generateTerminalCommand",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g"
      },
      {
        "command": "accure-code.agentManagerOpen",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      },
      {
        "command": "accure-code.addToContext",
        "key": "ctrl+k ctrl+a",
        "mac": "cmd+k cmd+a",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "accure-code.agentManager.previousSession",
        "key": "ctrl+alt+up",
        "mac": "cmd+alt+up",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.nextSession",
        "key": "ctrl+alt+down",
        "mac": "cmd+alt+down",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.previousTab",
        "key": "ctrl+alt+left",
        "mac": "cmd+alt+left",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.nextTab",
        "key": "ctrl+alt+right",
        "mac": "cmd+alt+right",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.search",
        "key": "ctrl+f",
        "mac": "cmd+f",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel' && !terminalFocus"
      },
      {
        "command": "accure-code.agentManager.showTerminal",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.runScript",
        "key": "ctrl+e",
        "mac": "cmd+e",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel' && (isMac || !terminalFocus)"
      },
      {
        "command": "accure-code.agentManager.toggleDiff",
        "key": "ctrl+d",
        "mac": "cmd+d",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.showShortcuts",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.newTab",
        "key": "ctrl+t",
        "mac": "cmd+t",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.newTerminal",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.closeTab",
        "key": "ctrl+w",
        "mac": "cmd+w",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.newWorktree",
        "key": "ctrl+n",
        "mac": "cmd+n",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.openWorktree",
        "key": "ctrl+shift+o",
        "mac": "cmd+shift+o",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.openPR",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.closeWorktree",
        "key": "ctrl+shift+w",
        "mac": "cmd+shift+w",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.advancedWorktree",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo1",
        "key": "ctrl+1",
        "mac": "cmd+1",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo2",
        "key": "ctrl+2",
        "mac": "cmd+2",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo3",
        "key": "ctrl+3",
        "mac": "cmd+3",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo4",
        "key": "ctrl+4",
        "mac": "cmd+4",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo5",
        "key": "ctrl+5",
        "mac": "cmd+5",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo6",
        "key": "ctrl+6",
        "mac": "cmd+6",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo7",
        "key": "ctrl+7",
        "mac": "cmd+7",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo8",
        "key": "ctrl+8",
        "mac": "cmd+8",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.agentManager.jumpTo9",
        "key": "ctrl+9",
        "mac": "cmd+9",
        "when": "activeWebviewPanelId == 'accure-code.AgentManagerPanel'"
      },
      {
        "command": "accure-code.cycleAgentMode",
        "key": "ctrl+.",
        "mac": "cmd+.",
        "when": "sideBarFocus && accure-code.sidebarVisible || activeWebviewPanelId == 'accure-code.AgentManagerPanel' || activeWebviewPanelId == 'accure-code.TabPanel'"
      },
      {
        "command": "accure-code.cyclePreviousAgentMode",
        "key": "ctrl+shift+.",
        "mac": "cmd+shift+.",
        "when": "sideBarFocus && accure-code.sidebarVisible || activeWebviewPanelId == 'accure-code.AgentManagerPanel' || activeWebviewPanelId == 'accure-code.TabPanel'"
      },
      {
        "command": "accure-code.autocomplete.cancelSuggestions",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && accure-code.autocomplete.hasSuggestions"
      },
      {
        "command": "accure-code.autocomplete.generateSuggestions",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && accure.autocomplete.enableSmartInlineTaskKeybinding && !github.copilot.completions.enabled"
      },
      {
        "command": "accure-code.autocomplete.showIncompatibilityExtensionPopup",
        "key": "ctrl+l",
        "mac": "cmd+l",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && accure.autocomplete.enableSmartInlineTaskKeybinding && github.copilot.completions.enabled"
      },
      {
        "command": "accure-code.autocomplete.nextEdit.acceptOrJump",
        "key": "tab",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && !suggestWidgetVisible && accure-code.nextEdit.hasPendingSuggestion"
      },
      {
        "command": "accure-code.autocomplete.nextEdit.dismiss",
        "key": "escape",
        "when": "editorTextFocus && !editorTabMovesFocus && !inSnippetMode && accure-code.nextEdit.hasPendingSuggestion"
      }
    ],
