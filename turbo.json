{
  "$schema": "https://v2-8-13.turborepo.dev/schema.json",
  "globalEnv": ["CI", "ACCURECODE_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "ACCURECODE_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@accurecode/cli#build": {
      "dependsOn": ["@accurecode/sdk#build"],
      "outputs": ["dist/**"]
    },
    "@accurecode/cli#test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "passThroughEnv": ["*"]
    },
    "test:ci": {
      "outputs": [".artifacts/unit/junit.xml"],
      "passThroughEnv": ["*"]
    },
    "@accurecode/cli#test:ci": {
      "dependsOn": ["^build"],
      "outputs": [".artifacts/unit/junit.xml"],
      "passThroughEnv": ["*"]
    },
    "@accurecode/accure-gateway#test:ci": {
      "outputs": [".artifacts/unit/junit.xml"]
    },
    "@accurecode/accure-docs#build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"],
      "env": ["POSTHOG_API_KEY", "FREE_TIER_AMOUNT", "NEXT_PUBLIC_POSTHOG_KEY", "NEXT_PUBLIC_POSTHOG_HOST"]
    },
    "@accurecode/accure-jetbrains#build": {
      "dependsOn": ["@accurecode/cli#build"],
      "outputs": ["build/distributions/**"]
    },
    "@accurecode/accure-jetbrains#typecheck": {
      "outputs": []
    },
    "@accurecode/accure-jetbrains#test:ci": {
      "outputs": [".artifacts/unit/junit.xml"]
    },
    "@opencode-ai/ui#test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@opencode-ai/ui#test:ci": {
      "dependsOn": ["^build"],
      "outputs": [".artifacts/unit/junit.xml"],
      "passThroughEnv": ["*"]
    }
  }
}
